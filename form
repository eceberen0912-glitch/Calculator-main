<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta
    name="viewport"
    content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0"
  >
  <meta http-equiv="X-UA-Compatible" content="ie=edge">
  <link rel="stylesheet" href="../../static/css/style.css"> 
  <title>Akıllı evler için enerji verimlilik hesaplayıcısı</title>
</head>
<body>
  <header class="header">
    <div class="header__text">
      <h1>Evinizin enerji verimliliğini hesaplayın!</h1>
      <p>Girişimde bulunun ve aşırı enerji tüketimi sorununu çözün!</p>
    </div>
  </header>
  <main>
    {% block content %}
    <form action="{{ url_for('submit_form') }}" method="post" class="form">
      <div class="user">
        <ul class="user-info">
            <li class="user-info__item">

                <label for="name">Sizin adınız</label>
                <input type="text" name="name" id="name" placeholder="Tam adınızı girin" required>
            </li>
            <li class="user-info__item">
                <!-- Görev 4. Kullanıcının e-posta adresi için bir giriş alanı oluşturun -->
               <label for="email">E-posta adresiniz</label>
                <input type="email" name="email" id="email" placeholder="E-posta adresinizi girin" required>
            </li>
        </ul>
        <!--Adres ve isim için alanlar-->
        <ul class="address-date">
            <li class="user-info__item">

                <label for="address">Adresinizi belirtin</label>
                <input type="text" name="address" id="address" placeholder="Adresiniz" required>
            </li>
            <li class="user-info__item">

                <label for="date">Uzmanlarımızın gelmesi için rahat olduğunuz tarihi belirtin</label>
                <input type="date" name="date" id="date" required>
            </li>
        </ul>
    </div>
    <button class="button" type="submit">Hazır!</button>
    </form>
    {% endblock %}
  </main>
  <footer>

  </footer>
</body>
</html>
<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<title>Enerji Tasarrufu Ölçer</title>
<link rel="stylesheet" href="style.css">
</head>
<body>

<button class="dark-toggle" onclick="toggleDark()">🌙 Dark Mode</button>

<h1 class="main__title">Enerji Tasarrufu Ölçer ⚡</h1>

<div class="form">
    <input type="number" id="eski" placeholder="Geçen Ay (kWh)">
    <input type="number" id="yeni" placeholder="Bu Ay (kWh)">

    <select id="enerjiTipi">
        <option value="elektrik">Elektrik</option>
        <option value="dogalgaz">Doğalgaz</option>
        <option value="gunes">Güneş Enerjisi</option>
    </select>

    <button onclick="hesapla()">Hesapla</button>

    <p id="sonuc"></p>
</div>

<script src="script.js"></script>
</body>
</html>
